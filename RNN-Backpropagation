import numpy as np

# dimensions
input_size = 4
hidden_size = 3
output_size = 3
sequence_length = 4
learning_rate = 0.01

# initialize weights 
Wx = np.random.randn(hidden_size, input_size) * 0.01
Wh = np.random.randn(hidden_size, hidden_size) * 0.01
Wy = np.random.randn(output_size, hidden_size) * 0.01

def softmax(x):
    exp_x = np.exp(x - np.max(x))
    return exp_x / np.sum(exp_x)

def forward(inputs):
    hs = {}
    hs[-1] = np.zeros((hidden_size, 1))
    ys = {}
    ps = {}

    for t in range(len(inputs)):
        x = inputs[t].reshape(-1, 1)
        
        hs[t] = np.tanh(Wx @ x + Wh @ hs[t-1])
        
        ys[t] = Wy @ hs[t] 
        ps[t] = softmax(ys[t])

    return hs, ps

def compute_loss(ps, targets):
    loss = 0
    for t in range(len(targets)):
        loss += -np.log(ps[t][targets[t], 0])
    return loss

def backward(inputs, hs, ps, targets):
    # Initialize gradients
    dWx = np.zeros_like(Wx)
    dWh = np.zeros_like(Wh)
    dWy = np.zeros_like(Wy)

    dh_next = np.zeros((hidden_size, 1))

    # Backpropagation through time (BPTT)
    for t in reversed(range(len(inputs))):
        dy = np.copy(ps[t])
        dy[targets[t]] -= 1

        dWy += dy @ hs[t].T

        dh = Wy.T @ dy + dh_next
        dh_raw = (1 - hs[t] ** 2) * dh

        dWx += dh_raw @ inputs[t].reshape(1, -1)
        dWh += dh_raw @ hs[t-1].T

        dh_next = Wh.T @ dh_raw

    return dWx, dWh, dWy

# training example
for epoch in range(100):
    # Generate random inputs and targets
    inputs = [np.random.randn(input_size) for _ in range(sequence_length)]
    targets = np.random.randint(0, output_size, sequence_length)

    # Forward pass
    hs, ps = forward(inputs)
    loss = compute_loss(ps, targets)

    # Backward pass
    dWx, dWh, dWy = backward(inputs, hs, ps, targets)

    # Update weights
    Wx -= learning_rate * dWx
    Wh -= learning_rate * dWh
    Wy -= learning_rate * dWy

    if epoch % 10 == 0:
        print("epoch:", epoch, "loss:", loss)
